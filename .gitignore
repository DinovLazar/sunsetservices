# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.local.example

# vercel
.vercel

# sanity studio (Phase 2.03)
/dist/
/.sanity/

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code local config
/.claude/

# lighthouse audit outputs (Phase 2.08 convention — committed scores live in completion reports)
/lighthouse/

# Termly document IDs (Phase B.03b — gitignored secrets file)
.termly-ids.txt

# Phase B.04 — validation harness temp artifacts (the committed copy of the
# report lives at src/_project-state/Phase-B-04-Validation-Report.md)
/scripts/.schema-validation-report.json
/scripts/.schema-validation-cache.json

# Phase B.05 — SEO validation harness temp artifacts (the committed copy
# of the table lives at src/_project-state/Phase-B-05-Completion.md)
/scripts/.seo-validation-report.json
/scripts/.seo-validation-cache.json

# Phase B.06 — a11y validation harness temp artifacts (the committed copy
# of the findings table lives at src/_project-state/Phase-B-06-Completion.md)
/scripts/.a11y-validation-report.json
/scripts/.a11y-validation-cache.json
/test-results/
/playwright-report/
/.playwright/
