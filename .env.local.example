# SunSet Services — .env.local.example
# Placeholder values for every variable .env.local should hold.
# This file IS committed. Copy it to .env.local and fill in real values.
# Rebuilt during Part 2 — Phase 01 (Account Creation Runway).
# Variables are appended as each service account is opened.

# ─────────────────────────────────────────────────────────────────────
# Phase 2.01 — provisioned 2026-05-10
# ─────────────────────────────────────────────────────────────────────

# Cloudflare (used in Part 3 Phase 3.11 onward)
# (No API key needed yet — DNS work uses the dashboard.)

# Sanity (used in Phase 2.03 onward)
SANITY_PROJECT_ID=
SANITY_DATASET=production

# Sanity — public client (Phase 2.03 onward; embedded in client bundle, no secret)
# Mirror these into Vercel for Production + Preview (REST API helper — see Vercel sync note below).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Sanity — write-scoped token (Phase 2.05 migration + Phase 2.16 automation agent — create in Sanity Manage → API → Tokens)
SANITY_API_WRITE_TOKEN=

# Vercel (set automatically during Phase 2.02 repo connection — no manual var here)

# Resend (used in Phase 2.08 onward; key created in Phase 2.01)
RESEND_API_KEY=

# Anthropic (used in Phase 2.09 chat widget + Phase 2.16 automation agent)
ANTHROPIC_API_KEY=
ANTHROPIC_ORG_ID=

# Telegram bot (used in Phase 2.15 lead alerts + Phase 2.16 agent approvals)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPERATOR_CHAT_ID=

# Google (DEFERRED to new Phase 2.13.2 per user decision; not in .env.local yet)
# GOOGLE_PLACES_API_KEY=
# SUNSET_SERVICES_PLACE_ID=
# GOOGLE_BUSINESS_PROFILE_ID=

# ─────────────────────────────────────────────────────────────────────
# Phase 2.07 — Calendly embed (added 2026-05-12)
# ─────────────────────────────────────────────────────────────────────
# Public — embedded in client bundle (no secret). The inline `widget.js`
# is lazy-loaded from `assets.calendly.com` only after the embed enters
# the viewport (IntersectionObserver, 200px rootMargin) or, on hard-flag
# disable / missing URL / withheld cookie consent, replaced by a static
# fallback card. Set ENABLED=true to render the real widget.
# Testing URL — replace with Erick's real Sunset Services Calendly URL
# before DNS cutover (Phase 3.12 checklist; see Sunset-Services-Decisions
# entry "2026-05-12 — Phase 2.07 uses user's personal Calendly URL").
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/dinovlazar2011
NEXT_PUBLIC_CALENDLY_ENABLED=true

# ─────────────────────────────────────────────────────────────────────
# Feature flags (set in later phases; listed here so the shape of .env.local is clear)
# ─────────────────────────────────────────────────────────────────────
# Master flag for /api/quote + /api/quote/partial (Phase 2.06). When false,
# both routes return 200 with no side effects (Phase 1.20 simulation
# behavior — Submit still redirects to /thank-you/).
WIZARD_SUBMIT_ENABLED=true
# Mautic CRM gate (Phase 2.06). Always false at Phase 2.06 — flips to true
# when Erick's self-hosted Mautic server is live and the real client lands.
MAUTIC_ENABLED=false
# Phase 2.09 flipped NEXT_PUBLIC_AI_CHAT_ENABLED to true (chat bubble live).
NEXT_PUBLIC_AI_CHAT_ENABLED=true
NEXT_PUBLIC_WIZARD_AUTOSAVE_ENABLED=true

# ─────────────────────────────────────────────────────────────────────
# Phase 2.06 — Quote wizard backend (added 2026-05-12)
# ─────────────────────────────────────────────────────────────────────
# Mautic placeholders — empty until Erick's server is live.
MAUTIC_BASE_URL=
MAUTIC_API_KEY=

# Resend lead-alert addresses. The FROM uses Resend's sandbox sender until
# Phase 2.08 verifies `sunsetservices.us` and ships branded HTML templates.
# The TO is dinovlazar2011@gmail.com (the Resend account's only verified
# address) at Phase 2.06 — sandbox mode rejects sends to any unverified
# recipient. Flips to info@sunsetservices.us in Phase 2.08 after domain
# verification. Tracked in Sunset-Services-Decisions.md.
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TO_EMAIL=dinovlazar2011@gmail.com

# ─────────────────────────────────────────────────────────────────────
# Phase 2.08 — Email templates + contact + newsletter (added 2026-05-12)
# ─────────────────────────────────────────────────────────────────────
# When false (Phase 2.08 default), every branded email reroutes to
# RESEND_TO_EMAIL with a sandbox banner inside the rendered HTML and a
# `[SANDBOX → <intended>]` prefix on the subject. Flip to true after
# sunsetservices.us is verified in Resend (see Sunset-Services-Decisions.md
# 2026-05-12 entry "Phase 2.08: Resend domain verification deferred").
RESEND_DOMAIN_VERIFIED=false

# Master kill switch for /api/contact. When false the route returns 200 +
# status:'simulated' (matches the Phase 2.06 WIZARD_SUBMIT_ENABLED pattern).
CONTACT_SUBMIT_ENABLED=true

# Master kill switch for /api/newsletter. Same pattern.
NEWSLETTER_SUBMIT_ENABLED=true

# ─────────────────────────────────────────────────────────────────────
# Phase 2.09 — AI chat backend (added 2026-05-12)
# ─────────────────────────────────────────────────────────────────────
# Master backend kill switch. When false, /api/chat returns 503
# `{status: 'disabled'}` and `/api/chat/lead` returns 200 `{status: 'simulated'}`.
# Defense-in-depth alongside the frontend NEXT_PUBLIC_AI_CHAT_ENABLED bubble guard.
AI_CHAT_ENABLED=true
# Anthropic model id used by /api/chat. Env-flippable so a snapshot can be
# pinned without code edits.
ANTHROPIC_MODEL=claude-sonnet-4-6
# Per-IP daily message ceiling enforced by src/lib/chat/rateLimit.ts (in-memory).
# Counters reset on Vercel function cold start — preview is SSO-gated, see
# Sunset-Services-Decisions.md "Phase 2.09 rate-limiter chosen + carryover".
CHAT_DAILY_LIMIT_PER_IP=50
# Per-IP burst guard in milliseconds — minimum gap between consecutive POSTs.
CHAT_BURST_INTERVAL_MS=2000

# ─────────────────────────────────────────────────────────────────────
# Phase 2.01 carryover — GCP credentials (added 2026-05-13 in Phase 2.10 A.1b)
# ─────────────────────────────────────────────────────────────────────
# These variables document the shape of the GCP credentials Phase 2.13.2 will need
# to populate. The project itself is already created on Goran's side ("Sunset Website");
# the Places API key + GBP OAuth credentials exist there too. They're synced into
# .env.local + Vercel when Goran emails them over (the credentials-handoff approach
# logged in Sunset-Services-Decisions.md, 2026-05-12).

# Google Cloud project that owns Places + GBP API access.
GCP_PROJECT_ID=
GCP_PROJECT_NUMBER=
GCP_PROJECT_NAME=Sunset Website

# Google Places API key — format: AIzaSy...
# Used by: Phase 2.16 daily review fetch + Phase 2.13.3 address autocomplete on wizard Step 4.
GOOGLE_PLACES_API_KEY=

# Google Business Profile OAuth credentials. The refresh token is generated in mini-phase
# 2.14a (a ~5-min screenshare with Goran AFTER Google approves the GBP API application
# that was filed on 2026-05-12 — a 2–6 week review window).
GBP_OAUTH_CLIENT_ID=
GBP_OAUTH_CLIENT_SECRET=
GBP_OAUTH_REFRESH_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# Phase 2.10 — Analytics stack (added 2026-05-13)
# ─────────────────────────────────────────────────────────────────────
# Google Tag Manager container ID. Created by Cowork in Phase 2.10 Part A.
# Format: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=

# Google Analytics 4 Measurement ID. Documentation only; GA4 connects through GTM.
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Microsoft Clarity project ID. Loaded directly (not through GTM).
# Format: ~10-char alphanumeric
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Master kill switch. Set false to disable banner + GTM + Clarity entirely.
# Vercel Analytics (Phase 2.02) is independent and is NOT affected by this flag.
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# ─────────────────────────────────────────────────────────────────────
# Phase 2.13 — ServiceM8 webhook (added 2026-05-14)
# ─────────────────────────────────────────────────────────────────────
# Master kill switch — when 'false', the webhook endpoint at
# /api/webhooks/servicem8 returns 200 + {status:'simulated',reason:'feature-flag'}
# without parsing the body, verifying the signature, or writing to Sanity.
# Flip to 'true' only after Erick adopts ServiceM8 and the real webhook secret
# is provisioned in ServiceM8's webhook configuration UI.
# See Sunset-Services-Decisions.md "2026-05-10 — ServiceM8 adoption deferred".
SERVICEM8_ENABLED=false

# HMAC-SHA256 secret ServiceM8 will use to sign webhook bodies. The route
# computes HMAC-SHA256(rawBody, this secret) as a hex digest and compares it
# (timing-safe) against the `x-servicem8-signature` request header. Required
# when SERVICEM8_ENABLED=true; leave empty while the flag is off.
SERVICEM8_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Phase 2.15 — Telegram bot infrastructure (added 2026-05-15)
# ─────────────────────────────────────────────────────────────────────
# Master kill switch for outbound Telegram sends + the inbound webhook at
# /api/webhooks/telegram. When 'false', the client no-ops with a single
# log line and returns {simulated:true}, and the webhook returns 200 +
# {status:'simulated',reason:'feature-flag'} without parsing the body or
# checking the secret header. Flip to 'true' AFTER (a) running
# `npm run telegram:setup -- <public-url>/api/webhooks/telegram` once per
# environment, and (b) confirming TELEGRAM_OPERATOR_CHAT_ID (Phase 2.01)
# points at the right person (currently Goran — swap to Erick at launch
# handover). The TELEGRAM_BOT_TOKEN + TELEGRAM_OPERATOR_CHAT_ID values are
# carried over from Phase 2.01.
TELEGRAM_ENABLED=false

# Shared secret Telegram echoes back in the X-Telegram-Bot-Api-Secret-Token
# header on every webhook POST. 64-hex random, generated once with
# `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`.
# Mirrored to Vercel (Production + Preview). The SAME value is passed as
# the `secret_token` arg to `setWebhook`. Re-generate ONLY if leakage is
# suspected — then re-run `npm run telegram:setup -- <url>` to re-register.
TELEGRAM_WEBHOOK_SECRET_TOKEN=

# Optional. Defaults to https://api.telegram.org. The verification harness
# at scripts/test-telegram-bot.mjs overrides this to point at a local mock
# server so automated tests never hit real Telegram. Leave unset in
# production and preview.
# TELEGRAM_API_BASE_URL=

# ─────────────────────────────────────────────────────────────────────
# Phase 2.16 — Automation agent Part A (cron jobs) (added 2026-05-15)
# ─────────────────────────────────────────────────────────────────────
# Required: Vercel Cron auth shared secret. Vercel sends this as
# `Authorization: Bearer ${CRON_SECRET}` on every scheduled trigger.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Monthly blog draft cron master kill switch. When 'true' (Phase 2.16 default),
# the route can run end-to-end: pick next topic, generate Anthropic draft,
# persist blogDraftPending, send Telegram approval. When 'false', returns 200
# + {status:'simulated',reason:'feature-flag'} without invoking Anthropic or
# writing Sanity. Use to pause monthly drafting without touching the cron
# schedule.
BLOG_DRAFT_CRON_ENABLED=true

# Weekly SEO summary cron master kill switch. When 'true', fetches the last-7-
# days GSC summary and sends a Markdown digest to the operator via Telegram.
# When 'false' (Phase 2.16 default), returns 200 + simulated without touching
# Google Search Console. Flips to 'true' at Phase 3.15 after GSC ownership
# verification on sunsetservices.us is set up.
GSC_ENABLED=false

# Google Search Console site URL (only consumed when GSC_ENABLED=true).
# Set to 'sc-domain:sunsetservices.us' when domain verification is set up at
# Phase 3.15. Leave empty until then.
GSC_SITE_URL=

# Service account JSON for GSC + GA4 read access — declared in the Phase 2.10
# block (search this file for GOOGLE_SERVICE_ACCOUNT_JSON if it lands later).
# Phase 2.16 references but does NOT add a second copy of this variable.
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Master kill switch for the Phase 2.16 blog-automation test routes
# (/api/test/blog-draft-run + /api/test/blog-draft-decision). When anything
# other than 'true' the routes return 404 + {status:'forbidden'}. The
# verification harness at scripts/test-blog-automation.mjs sets it to 'true'
# for the spawned test server only. Leave unset on Vercel — Production +
# Preview ship the routes in the bundle but they are dead.
# BLOG_AUTOMATION_TEST_ROUTES_ENABLED=

# Test-routes-only Cron auth secret (Phase 2.16). When the harness POSTs to
# /api/test/blog-draft-run, the route checks this header value instead of the
# production CRON_SECRET so a leaked production secret can't be used to drive
# the test route, and vice versa.
# TEST_ROUTES_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Phase B.03 — Legal pages (Termly iframe embed, Path B) (added 2026-05-15,
# rolled back to iframe in B.03d 2026-05-16)
# ─────────────────────────────────────────────────────────────────────
# Termly is the provider for Privacy + Terms hosted policies. The embed
# is rendered via Termly's `app.termly.io/embed-policy.min.js` script,
# which finds `<div name="termly-embed" data-id=… data-type="iframe">`
# and rewrites it to an iframe pointing at app.termly.io. When the
# per-(type × locale) doc ID is empty, the embed component renders the
# brand-styled "preparing" fallback card instead of an empty embed.
#
# State on Vercel (Production + Preview) as of Phase B.03d:
#   WEBSITE_ID + PRIVACY_EN_ID  → populated (from Cowork B.03b)
#   PRIVACY_ES_ID, TERMS_EN_ID, TERMS_ES_ID → empty (Cowork hasn't
#   provided IDs yet; those 3 routes stay on the fallback card).
#
# Mirror Vercel values here for local dev. Source of truth is the
# project-root `.termly-ids.txt` (gitignored).

# Termly tenant-level website ID. Format: UUID.
NEXT_PUBLIC_TERMLY_WEBSITE_ID=

# Termly document IDs — one per (policy type × locale) pairing.
NEXT_PUBLIC_TERMLY_PRIVACY_EN_ID=
NEXT_PUBLIC_TERMLY_PRIVACY_ES_ID=
NEXT_PUBLIC_TERMLY_TERMS_EN_ID=
NEXT_PUBLIC_TERMLY_TERMS_ES_ID=

# ─────────────────────────────────────────────────────────────────────
# Phase B.08 — Sanity → site instant revalidation (added 2026-05-16)
# ─────────────────────────────────────────────────────────────────────
# SANITY_REVALIDATE_SECRET: random 64-hex string. Sanity webhook signs the
#   request body with HMAC-SHA256 using this secret; the route at
#   /api/revalidate verifies the `sanity-webhook-signature` header via
#   next-sanity/webhook parseBody(). Generate with:
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   Then paste the SAME value into the Sanity webhook config in
#   manage.sanity.io (see Phase-B-08-Completion.md §"User-runnable next
#   step" for the field-by-field block).
# REVALIDATE_TEST_ROUTES_ENABLED: master kill switch for
#   /api/test/revalidate. Leave UNSET on Vercel. Set to 'true' only locally
#   for the verification harness (scripts/test-revalidate-webhook.mjs sets
#   it on the spawned test server only). Auth on the test route reuses the
#   Phase 2.16 TEST_ROUTES_SECRET — no new secret introduced.
SANITY_REVALIDATE_SECRET=
REVALIDATE_TEST_ROUTES_ENABLED=

# ─────────────────────────────────────────────────────────────────────
# Phase 2.17 — Portfolio publish pipeline (added 2026-05-15)
# ─────────────────────────────────────────────────────────────────────
# Master flag for the on-demand portfolio-draft pipeline. When false (Phase
# 2.17 default), the webhook trigger no-ops with a single log line and the
# test route returns 200 + {status:'simulated',reason:'feature-flag'} without
# invoking Anthropic, downloading photos, or writing Sanity. Flip to 'true'
# only AFTER Erick adopts ServiceM8 and Phase 2.13's SERVICEM8_ENABLED is
# also flipped on. Pipeline gates on BOTH flags — if either is false, no
# portfolio draft is generated.
PORTFOLIO_DRAFT_ENABLED=false

# Sub-flag for the GBP write legs (photo upload + Google Post creation).
# Stays 'false' until Phase 2.17a wires the real GBP client AFTER Phase 2.14
# lands (the GBP write client + Goran's GBP_OAUTH_CLIENT_SECRET +
# GBP_OAUTH_REFRESH_TOKEN). With this flag false, the stubs in
# src/lib/automation/portfolio/gbpPublish.ts return
# {skipped:true,reason:'gbp-deferred'} and the rest of the pipeline runs
# normally (the Telegram approval + Sanity project doc creation legs are
# independent of GBP).
GBP_PORTFOLIO_PUBLISH_ENABLED=false

# PORTFOLIO_AUTOMATION_TEST_ROUTES_ENABLED — leave unset in .env.local +
# Vercel. scripts/test-portfolio-automation.mjs sets it to 'true' on the
# spawned test server only. When unset, the two test routes
# (/api/test/portfolio-pipeline-run + /api/test/portfolio-decision) return
# 404 + {status:'forbidden'} even with a valid auth header. Reuses the
# Phase 2.16 TEST_ROUTES_SECRET for authentication (no new shared secret).
# PORTFOLIO_AUTOMATION_TEST_ROUTES_ENABLED=

# ─────────────────────────────────────────────────────────────────────
# Vercel sync (added in Phase 2.02)
# ─────────────────────────────────────────────────────────────────────
# All variables documented above are also configured in Vercel for
# Production + Preview environments (no Development). To sync a new
# variable to Vercel:
#
#   vercel env add <NAME> production --value <V> --yes
#   vercel env add <NAME> preview <branch> --value <V> --yes
#
# Verify with: vercel env ls
#
# Caveat: in Claude Code agent mode, `vercel env add NAME preview`
# WITHOUT a branch positional emits an action_required JSON and exits,
# even with --yes (CLI plugin enforcement at commands/env/index.js:948).
# To add to ALL preview branches in one shot, POST directly to the REST API:
#
#   POST https://api.vercel.com/v10/projects/<projectId>/env?upsert=true&teamId=<orgId>
#   { "type":"sensitive"|"plain", "key":"<NAME>", "value":"<V>", "target":["production","preview"] }
#
# Token lives at %APPDATA%\xdg.data\com.vercel.cli\auth.json.
# IDs in .vercel/project.json. Phase 2.02 completion report has the
# PowerShell helper.
