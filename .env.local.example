# Feature flags
AI_CHAT_ENABLED=true

# Phase 1.20 wizard + chat UI flags. Defaults are correct for Part-1 dev:
#   - chat OFF (bubble doesn't render — flip to true to preview the widget)
#   - wizard submit OFF (Submit click simulates → /thank-you/, no POST)
#   - wizard autosave ON (Steps 1–3 only persist; PII never leaves React)
NEXT_PUBLIC_AI_CHAT_ENABLED=false
WIZARD_SUBMIT_ENABLED=false
NEXT_PUBLIC_WIZARD_AUTOSAVE_ENABLED=true
